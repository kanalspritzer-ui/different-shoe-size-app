# Backend-Konfiguration
# Passen Sie die API_BASE_URL an Ihre Umgebung an:

# Für Android Emulator (localhost wird zu 10.0.2.2)
API_BASE_URL=http://10.0.2.2:3000

# Für physisches Android-Gerät (ersetzen Sie die IP)
# API_BASE_URL=http://192.168.1.100:3000

# Für Produktionsserver
# API_BASE_URL=https://api.different-shoe-size.de

# API-Timeout in Millisekunden
API_TIMEOUT=10000

# Debug-Modus
DEBUG=true
